# Wayfinder backend environment (copy to backend/.env)

ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:8080"]

# Database & cache
DATABASE_URL=postgresql+psycopg://wayfinder:wayfinder@localhost:5432/wayfinder
REDIS_URL=redis://localhost:6379/0

# Supabase JWT verification (one of JWKS URL or shared secret)
SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# LLM vendor: gemini | claude | gpt
LLM_VENDOR=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Real providers (leave blank to use mock providers / zero paid keys)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
OPENWEATHERMAP_API_KEY=
MAPBOX_ACCESS_TOKEN=
TICKETMASTER_API_KEY=
